import * as React from "react";
import { useState, useRef } from "react";
import { Upload, Loader2, Image as ImageIcon } from "lucide-react";
import { Button } from "./ui/Button";
import { analyzeImage } from "../services/gemini";
import { GaugeChart } from "./ui/GaugeChart";
import { motion } from "motion/react";
import exifr from 'exifr';

export function ImageAnalyzer() {
  const [preview, setPreview] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [result, setResult] = useState<any>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleFile = async (file: File) => {
    if (!file) return;
    
    // Create preview
    const objectUrl = URL.createObjectURL(file);
    setPreview(objectUrl);
    setIsLoading(true);
    setResult(null);

    try {
      // Extract EXIF
      const exifData = await exifr.parse(file).catch(() => null);

      // Convert image to base64
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = async () => {
        const base64Data = (reader.result as string).split(',')[1];
        
        const res = await analyzeImage(base64Data, file.type, exifData);
        setResult({ ...res, exifData });

        // Submit mock check to community feed
        fetch('/api/feed', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'image', content: file.name, status: res.status, score: res.score })
        }).catch(console.error);

        setIsLoading(false);
      };
      
    } catch (error) {
      console.error(error);
      setResult({ score: 0, status: "Error", reasons: ["Analysis failed."] });
      setIsLoading(false);
    }
  };

  const onFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files && e.target.files[0]) {
      handleFile(e.target.files[0]);
    }
  };

  return (
    <div className="flex flex-col gap-6">
      <div 
        className="flex-1 min-h-[120px] bg-slate-50 border border-slate-200 border-dashed rounded-lg p-6 flex flex-col items-center justify-center text-center cursor-pointer hover:bg-slate-100 transition-colors"
        onClick={() => fileInputRef.current?.click()}
      >
        <div className="w-10 h-10 mb-3 rounded-full bg-white border border-slate-200 shadow-sm flex items-center justify-center text-slate-600">
          <Upload className="w-5 h-5" />
        </div>
        <p className="text-sm font-bold text-slate-800">클릭하여 이미지 업로드 또는 드래그 앤 드롭</p>
        <p className="text-xs text-slate-500 mt-1">지원 형식: JPEG, PNG, WEBP (최대 5MB)</p>
        <input 
          type="file" 
          ref={fileInputRef} 
          className="hidden" 
          accept="image/*" 
          onChange={onFileChange} 
        />
      </div>

      {preview && (
        <div className="flex flex-col gap-6">
          <div className="grid md:grid-cols-2 gap-6">
              <div className="rounded-xl overflow-hidden border border-slate-200 bg-slate-100 flex items-center justify-center h-48 relative shadow-sm">
                {isLoading && (
                 <div className="absolute inset-0 bg-slate-900/10 z-10 flex items-center justify-center backdrop-blur-sm">
                   <Loader2 className="w-8 h-8 text-indigo-600 animate-spin" />
                 </div>
                )}
                <img src={preview} alt="미리보기" className="max-w-full max-h-full object-contain" />
              </div>
              {result?.exifData && (
                <div className="bg-slate-50 px-5 py-4 rounded-xl border border-slate-200 shadow-sm overflow-auto h-48">
                  <h4 className="text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-3 flex items-center">
                    <ImageIcon className="w-3 h-3 mr-1" /> EXIF 메타데이터 (사진 정보)
                  </h4>
                  <div className="text-[11px] text-slate-600 font-mono space-y-1.5 break-all">
                    {Object.entries(result.exifData).slice(0, 10).map(([key, value]) => (
                      <div key={key} className="flex justify-between border-b border-slate-200/50 pb-1">
                        <span className="font-semibold text-slate-700">{key}:</span>
                        <span className="truncate ml-2 text-right">{String(value)}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}
          </div>

          {result && (
            <motion.div initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} className="grid md:grid-cols-2 gap-6">
              <div className="bg-white rounded-xl border border-slate-200 shadow-sm p-6 flex flex-col items-center justify-center">
                <h3 className="text-xs font-bold uppercase tracking-wider text-slate-400 mb-6">신뢰도 점수 (Confidence Score)</h3>
                <GaugeChart score={result.score} />
                <div className="mt-4 text-center">
                    <span className="text-sm font-bold text-slate-800 uppercase px-3 py-1 bg-slate-100 rounded border border-slate-200">
                      {result.status}
                    </span>
                </div>
              </div>

              <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
                <div className="bg-slate-50 px-5 py-3 border-b border-slate-200 flex justify-between items-center">
                  <h3 className="text-xs font-bold uppercase tracking-wider text-slate-500">포렌식 분석 결과 (조작 흔적)</h3>
                </div>
                <div className="flex-1 overflow-y-auto">
                  <div className="divide-y divide-slate-100">
                      {result.reasons?.map((reason: string, i: number) => (
                        <div key={i} className="p-4 hover:bg-slate-50 transition-colors">
                          <div className="flex items-start gap-3">
                            <div className="mt-1 w-2 h-2 rounded-full bg-indigo-500 flex-shrink-0"></div>
                            <p className="text-[13px] font-medium text-slate-800 leading-snug">{reason}</p>
                          </div>
                        </div>
                      ))}
                  </div>
                </div>
              </div>
            </motion.div>
          )}
        </div>
      )}
    </div>
  );
}
